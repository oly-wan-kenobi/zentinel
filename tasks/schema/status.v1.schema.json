{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/tasks.status.v1.schema.json",
  "title": "zentinel task status",
  "type": "object",
  "required": [
    "schema_version",
    "active_task",
    "next_task",
    "completed_tasks",
    "blocked_tasks",
    "blocked_task_details",
    "last_validation",
    "completion_evidence",
    "clean_handoff_baseline",
    "history"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "zentinel.tasks.status.v1"
    },
    "active_task": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{3}$"
    },
    "next_task": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{3}$"
    },
    "completed_tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{3}$"
      }
    },
    "blocked_tasks": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{3}$"
      }
    },
    "blocked_task_details": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task",
          "reason",
          "blocker_type",
          "evidence",
          "attempted_recovery",
          "prerequisite_task",
          "required_prerequisite_task",
          "requires_user_input",
          "edits_state",
          "notes"
        ],
        "additionalProperties": false,
        "properties": {
          "task": {
            "type": "string",
            "pattern": "^[0-9]{3}$"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "blocker_type": {
            "enum": ["missing_prerequisite", "scope_gap", "external_input", "spec_ambiguity", "prior_task_regression"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "attempted_recovery": {
            "type": "string",
            "minLength": 1
          },
          "prerequisite_task": {
            "type": ["string", "null"],
            "pattern": "^[0-9]{3}$"
          },
          "required_prerequisite_task": {
            "type": ["string", "null"],
            "pattern": "^[0-9]{3}$"
          },
          "requires_user_input": {
            "type": "boolean"
          },
          "edits_state": {
            "enum": ["no_edits", "task_control_only", "reverted", "preserved_behind_tests"]
          },
          "notes": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "last_validation": {
      "type": "object",
      "required": ["command", "status", "notes"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string"
        },
        "status": {
          "enum": ["not_run", "passed", "failed"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "completion_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task",
          "failing_evidence",
          "implementation_summary",
          "files_changed",
          "tests_added",
          "tests_run",
          "validator_result",
          "dogfooding_implication",
          "follow_up_tasks"
        ],
        "additionalProperties": false,
        "properties": {
          "task": {
            "type": "string",
            "pattern": "^[0-9]{3}$"
          },
          "failing_evidence": {
            "type": "string"
          },
          "implementation_summary": {
            "type": "string"
          },
          "files_changed": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tests_added": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tests_run": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "validator_result": {
            "type": "object",
            "required": ["command", "status", "notes"],
            "additionalProperties": false,
            "properties": {
              "command": {
                "type": "string"
              },
              "status": {
                "const": "passed"
              },
              "notes": {
                "type": "string"
              }
            }
          },
          "dogfooding_implication": {
            "type": "string"
          },
          "follow_up_tasks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "gap_registry_rows_changed": {
            "type": "object",
            "patternProperties": {
              "^tests/coverage-gaps/[^/]+\\.v1\\.json$": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "task_control_changes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "clean_handoff_baseline": {
      "type": ["object", "null"],
      "required": ["task", "source_commit", "files", "notes"],
      "additionalProperties": false,
      "properties": {
        "task": {
          "type": "string",
          "pattern": "^[0-9]{3}$"
        },
        "source_commit": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event", "task", "notes"],
        "additionalProperties": false,
        "properties": {
          "event": {
            "type": "string"
          },
          "task": {
            "type": ["string", "null"],
            "pattern": "^[0-9]{3}$"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
