{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/tasks.queue.v1.schema.json",
  "title": "zentinel task queue",
  "type": "object",
  "required": ["schema_version", "ordering", "tasks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "zentinel.tasks.queue.v1"
    },
    "ordering": {
      "const": "sequential"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "file",
          "phase",
          "state",
          "dependencies",
          "allowed_files",
          "forbidden_files"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{3}$"
          },
          "order": {
            "type": "string",
            "pattern": "^[0-9]{3}(\\.[0-9]+)*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "pattern": "^tasks/[0-9]{3}-.+\\.md$"
          },
          "phase": {
            "type": "integer",
            "minimum": 0
          },
          "state": {
            "enum": ["queued", "active", "blocked", "implemented", "verified", "complete", "superseded"]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[0-9]{3}$"
            }
          },
          "allowed_files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "forbidden_files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
