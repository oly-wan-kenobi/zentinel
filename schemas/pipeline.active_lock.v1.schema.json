{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/pipeline.active_lock.v1.schema.json",
  "title": "zentinel pipeline active lock v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "state",
    "queue_order",
    "queue_file",
    "status_file",
    "context_packet",
    "created_by_role",
    "source_commit",
    "working_tree_state"
  ],
  "properties": {
    "schema_version": { "const": "zentinel.pipeline.active_lock.v1" },
    "task_id": { "type": "string", "pattern": "^[0-9]{3}$" },
    "state": { "const": "active" },
    "queue_order": { "type": "string" },
    "queue_file": { "type": "string" },
    "status_file": { "type": "string" },
    "context_packet": { "type": "string" },
    "created_by_role": { "type": "string", "minLength": 1 },
    "source_commit": { "type": "string" },
    "working_tree_state": { "enum": ["clean", "dirty"] }
  }
}
