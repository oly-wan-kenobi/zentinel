{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/pipeline.verification.v1.schema.json",
  "title": "zentinel pipeline verification record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "status",
    "stages",
    "residual_risk",
    "recommendation"
  ],
  "properties": {
    "schema_version": { "const": "zentinel.pipeline.verification.v1" },
    "task_id": { "type": "string", "pattern": "^[0-9]{3}$" },
    "status": { "enum": ["passed", "failed", "blocked", "not_applicable"] },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "required", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "status": { "enum": ["passed", "failed", "blocked", "not_applicable"] },
          "command": { "type": "string" },
          "artifact": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "residual_risk": { "type": "array", "items": { "type": "string" } },
    "recommendation": { "enum": ["complete", "block", "retry", "escalate"] }
  }
}
