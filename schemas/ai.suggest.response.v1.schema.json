{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/ai.suggest.response.v1.schema.json",
  "title": "zentinel AI suggest response v1",
  "type": "object",
  "required": ["schema_version", "classification", "suggestions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "zentinel.ai.suggest.response.v1" },
    "classification": {
      "enum": [
        "boundary_missing",
        "null_path_missing",
        "error_path_missing",
        "cleanup_path_missing",
        "comptime_case_missing",
        "logical_case_missing",
        "constant_case_missing",
        "possibly_equivalent",
        "unclear"
      ]
    },
    "suggestions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["title", "test_name", "intent", "example_values", "target_file"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "test_name": { "type": "string" },
          "intent": { "type": "string" },
          "example_values": { "type": "array", "items": { "type": "string" } },
          "target_file": { "type": "string" }
        }
      }
    }
  }
}
