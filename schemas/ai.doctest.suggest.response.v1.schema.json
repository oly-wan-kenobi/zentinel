{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/ai.doctest.suggest.response.v1.schema.json",
  "title": "zentinel doctest AI suggest response v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suggestions"],
  "properties": {
    "schema_version": { "const": "zentinel.ai.doctest.suggest.response.v1" },
    "suggestions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target_file", "line_hint", "reason", "block"],
        "properties": {
          "target_file": { "type": "string", "minLength": 1 },
          "line_hint": { "type": ["integer", "null"], "minimum": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "block": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
