{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zentinel.dev/schemas/doctest.report.v1.schema.json",
  "title": "zentinel doctest report v1",
  "type": "object",
  "required": ["schema_version", "run", "summary", "cases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "zentinel.doctest.report.v1" },
    "run": { "$ref": "#/$defs/run" },
    "summary": { "$ref": "#/$defs/summary" },
    "cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "error", "zentinel_version", "zig_version", "command", "project_root", "started_at", "duration_ms"],
      "properties": {
        "id": { "type": "string" },
        "status": { "enum": ["completed", "failed", "internal_error"] },
        "error": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/run_error" }
          ]
        },
        "zentinel_version": { "type": "string" },
        "zig_version": { "type": "string" },
        "command": { "type": "string" },
        "project_root": { "type": "string" },
        "started_at": { "type": "string" },
        "duration_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "run_error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "phase", "details"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "phase": { "enum": ["internal", "parser", "extractor", "runner", "snapshot", "report"] },
        "details": { "type": "array", "items": { "type": "string" } }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "passed", "failed", "compile_error", "expected_compile_error", "timeout", "skipped", "invalid"],
      "properties": {
        "total": {
          "comment": "For zentinel doctest --mutate this still counts only preflight non-mutation doctest entries; mutation entries are counted only in summary.mutation.",
          "type": "integer",
          "minimum": 0
        },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "compile_error": { "type": "integer", "minimum": 0 },
        "expected_compile_error": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "invalid": { "type": "integer", "minimum": 0 },
        "mutation": {
          "comment": "Optional additive task-061 mutation-aware summary; present only for zentinel doctest --mutate reports.",
          "$ref": "#/$defs/mutation_summary"
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "file", "line_start", "line_end", "source_ref", "block_refs", "kind", "status", "expectation", "command", "result", "diagnostics", "advisory"],
      "properties": {
        "id": { "type": "string" },
        "file": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "source_ref": { "type": "string" },
        "block_refs": { "type": "array", "items": { "type": "string" } },
        "kind": { "enum": ["zig_compile_pass", "zig_test", "zig_compile_fail", "cli", "config", "config_fail", "mutation"] },
        "status": { "enum": ["passed", "failed", "compile_error", "expected_compile_error", "timeout", "skipped", "invalid", "killed", "survived", "compiler_crash"] },
        "expectation": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mode", "block_ref"],
              "properties": {
                "mode": { "$ref": "#/$defs/match_mode" },
                "block_ref": { "type": "string" }
              }
            }
          ]
        },
        "command": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/command" }
          ]
        },
        "result": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/result" }
          ]
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        },
        "advisory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ai"],
          "properties": {
            "ai": {
              "oneOf": [
                { "type": "null" },
                { "type": "object", "additionalProperties": false }
              ]
            }
          }
        },
        "mutation": {
          "comment": "Optional additive task-061 extension. Present only for case.kind = \"mutation\" entries; absent for ordinary doctest cases so existing reports are unchanged.",
          "$ref": "#/$defs/case_mutation"
        }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "mutation" } }, "required": ["kind"] },
          "then": {
            "required": ["mutation"],
            "properties": {
              "id": { "pattern": "^dm_[0-9a-hjkmnp-tv-z]{26}$" },
              "status": { "enum": ["killed", "survived", "compile_error", "compiler_crash", "timeout", "skipped", "invalid"] }
            }
          },
          "else": {
            "properties": {
              "status": { "enum": ["passed", "failed", "compile_error", "expected_compile_error", "timeout", "skipped", "invalid"] }
            }
          }
        }
      ]
    },
    "case_mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doctest_case_id", "mutant_id", "operator", "mutated_diff", "survivor_ref", "runner_evidence"],
      "properties": {
        "doctest_case_id": { "type": "string", "pattern": "^dt_[0-9a-hjkmnp-tv-z]{26}$" },
        "mutant_id": { "type": "string" },
        "operator": { "type": "string" },
        "mutated_diff": { "type": "array", "items": { "type": "string" } },
        "survivor_ref": {
          "comment": "Non-null only when the enclosing case.status = \"survived\"; null for every other status.",
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^ds_[0-9a-hjkmnp-tv-z]{26}$" }
          ]
        },
        "runner_evidence": { "$ref": "#/$defs/mutation_runner_evidence" }
      }
    },
    "mutation_runner_evidence": {
      "type": "object",
      "additionalProperties": false,
      "comment": "Closed mutation-aware doctest runner evidence; failure_kind is always present so AI never infers the runner outcome class from prose.",
      "required": ["status", "command", "exit_code", "timed_out", "failure_kind", "stdout_excerpt", "stderr_excerpt", "failure_summary", "skip_reason"],
      "properties": {
        "status": { "type": "string" },
        "command": { "$ref": "#/$defs/command" },
        "exit_code": { "type": ["integer", "null"] },
        "timed_out": { "type": "boolean" },
        "failure_kind": { "enum": ["none", "compile_error", "test_failure", "compiler_crash", "timeout", "skipped"] },
        "stdout_excerpt": { "type": "string" },
        "stderr_excerpt": { "type": "string" },
        "failure_summary": { "type": "string" },
        "skip_reason": { "type": ["string", "null"] }
      }
    },
    "mutation_summary": {
      "type": "object",
      "additionalProperties": false,
      "comment": "Optional additive task-061 extension. Counts only mutation cases; the top-level summary still counts only preflight non-mutation doctest entries.",
      "required": ["total", "killed", "survived", "compile_error", "compiler_crash", "timeout", "skipped", "invalid"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "killed": { "type": "integer", "minimum": 0 },
        "survived": { "type": "integer", "minimum": 0 },
        "compile_error": { "type": "integer", "minimum": 0 },
        "compiler_crash": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "invalid": { "type": "integer", "minimum": 0 }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original", "argv", "cwd", "environment_policy", "shell"],
      "properties": {
        "original": { "type": "string" },
        "argv": { "type": "array", "items": { "type": "string" } },
        "cwd": { "type": "string" },
        "environment_policy": { "const": "minimal" },
        "shell": { "type": "boolean" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code", "timed_out", "duration_ms", "stdout_excerpt", "stderr_excerpt", "normalized_stdout_excerpt", "normalized_stderr_excerpt", "snapshot", "failure_summary"],
      "properties": {
        "exit_code": { "type": ["integer", "null"] },
        "timed_out": { "type": "boolean" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "stdout_excerpt": { "type": "string" },
        "stderr_excerpt": { "type": "string" },
        "normalized_stdout_excerpt": { "type": "string" },
        "normalized_stderr_excerpt": { "type": "string" },
        "snapshot": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/snapshot" }
          ]
        },
        "failure_summary": { "type": "string" }
      }
    },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_excerpt", "actual_excerpt", "normalized_expected_excerpt", "normalized_actual_excerpt", "match_mode", "expected_block_ref", "actual_ref", "matched"],
      "properties": {
        "expected_excerpt": { "type": "string" },
        "actual_excerpt": { "type": "string" },
        "normalized_expected_excerpt": { "type": "string" },
        "normalized_actual_excerpt": { "type": "string" },
        "match_mode": { "$ref": "#/$defs/match_mode" },
        "expected_block_ref": { "type": ["string", "null"] },
        "actual_ref": { "enum": ["stdout", "stderr", "diagnostic", "json", "report"] },
        "matched": { "type": "boolean" }
      }
    },
    "match_mode": { "enum": ["exact", "contains", "regex", "json", "json_subset", "json_unordered", "diagnostic"] }
  }
}
